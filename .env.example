# Copy to .env and fill in. NEVER commit .env: it holds credentials.
# docker compose auto-loads this file and injects the values into the app
# container's process environment (the backend reads them from os.environ; it
# does no dotenv loading of its own).

# --- LLM backend (configure at least one) ---

# Anthropic (Claude, direct API). Read by the Anthropic SDK on the backend; it is
# never entered in the browser.
ANTHROPIC_API_KEY=

# Ollama endpoint. Leave blank to use the per-request host chosen in the UI.
# To reach an Ollama server on the Docker host, use host.docker.internal:
#   OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=
